                      "completed"
                    ]
                  },
                  "activeForm": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "content",
                  "status",
                  "activeForm"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
