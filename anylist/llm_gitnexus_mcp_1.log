              "minLength": 2
            },
            "allowed_domains": {
              "description": "Only include search results from these domains",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "blocked_domains": {
              "description": "Never include search results from these domains",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false
        }
      },
