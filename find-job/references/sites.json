      "login_required": false,
      "search_url": "https://www.zhipin.com/web/geek/jobs?city={cityCode}&jobType={jobType}&salary={salary}&experience={experience}&query={keyword}",
      "api_endpoint": "https://www.zhipin.com/wapi/zpgeek/search/joblist.json",
      "api_params": {
        "scene": "1",
        "query": "{keyword}",
        "city": "{cityCode}",
        "experience": "{exp}",
        "jobType": "{jobType}",
        "salary": "{salary}",
        "page": "{page}",
        "pageSize": "10"
      },
      "city_codes": {
        "北京": "101010100",
        "上海": "101020100",
        "广州": "101280100",
        "深圳": "101280600",
        "杭州": "101210100",
        "成都": "101270100",
        "南京": "101190100",
        "武汉": "101200100",
        "西安": "101110100",
        "苏州": "101190400"
      },
      "salary_codes": {
        "不限": "0",
        "10-20K": "404",
        "20-35K": "405",
        "35-50K": "406",
        "50K+": "407"
      },
      "experience_codes": {
        "应届生": "103",
        "1-3年": "104",
        "3-5年": "105",
        "5-10年": "106",
        "10年以上": "107"
      },
      "response_mapping": {
        "list_path": "zpData.jobList[]",
        "total_path": "zpData.resCount",
        "has_more_path": "zpData.hasMore",
        "fields": {
          "title": "jobName",
          "salary_plaintext": "salaryDesc",
          "company": "brandName",
          "industry": "brandIndustry",
          "stage": "brandStageName",
          "scale": "brandScaleName",
          "experience": "jobExperience",
          "degree": "jobDegree",
          "city": "cityName",
          "district": "areaDistrict",
          "business_district": "businessDistrict",
          "skills": "skills",
          "welfare": "welfareList",
          "is_headhunter": "proxyJob",
          "encrypt_job_id": "encryptJobId",
          "url_template": "https://www.zhipin.com/job_detail/{encryptJobId}.html"
        }
      },
      "known_pitfalls": [
        "DOM 薪资 PUA 字体加密（U+E031-U+E038），textContent 为乱码，必须用 API 的 salaryDesc 字段",
        "CDP curl 需加 --noproxy '*' 避免 http_proxy 干扰返回 502",
        "API URL 多参数时 /new 可能截断只保留第一个参数，建议 navigate 到完整 URL 或用 eval 执行 fetch",
        "搜索为宽泛匹配，需额外对结果做关键词二次过滤",
        "proxyJob=1 为猎头发布，公司名显示「某XXX公司」，真实公司信息隐藏",
        "brandLogo 在猎头岗位为默认占位图"
      ],
      "effective_patterns": [
        "CDP 先打开搜索页获取 Cookie → navigate 到 API 端点 → eval 提取 body.innerText",
        "在 CDP 页面内用 eval 执行 fetch() 直接调用 API，绕过代理参数截断",
        "多页通过 page 参数翻页，控制频率避免风控",
        "多条件组合可并行子 Agent 各自在自己的 CDP tab 中操作"
      ],
      "site_pattern_ref": "site-patterns/zhipin.com.md"
    },
