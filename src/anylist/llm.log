            "tool_use_id": "toolu_12610c9c382d4ba98dd1211f",
            "type": "tool_result",
            "content": "     1→import json\n     2→import os\n     3→import httpx\n     4→from datetime import datetime\n     5→from fastapi import FastAPI, Request\n     6→from starlette.responses import StreamingResponse, Response\n     7→\n     8→# ──────────────────────────────────────────────\n     9→# 配置区 —— 按需修改\n    10→# ──────────────────────────────────────────────\n    11→\n    12→UPSTREAM = \"https://coding.dashscope.aliyuncs.com/apps/anthropic\"\n    13→DASHSCOPE_API_KEY = os.environ.get(\"DASHSCOPE_API_KEY\", \"sk-sp-xxx\")\n    14→\n    15→\n    16→# ──────────────────────────────────────────────\n    17→# Logger\n    18→# ──────────────────────────────────────────────\n    19→\n    20→class AppLogger:\n    21→    def __init__(self, log_file=\"llm.log\"):\n    22→        self.log_file = log_file\n    23→        self.round_count = 0\n    24→        with open(self.log_file, \"w\") as f:\n    25→            f.write(\"\")\n    26→    \n    27→    def get_timestamp(self):\n    28→        return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    29→    \n    30→    def increment_round(self):\n    31→        self.round_count += 1\n    32→        return self.round_count\n    33→    \n    34→    def log(self, message: str):\n    35→        timestamp = self.get_timestamp()\n    36→        formatted_message = f\"[{timestamp}] {message}\"\n    37→        with open(self.log_file, \"a\") as f:\n    38→            f.write(formatted_message + \"\\n\")\n    39→        print(formatted_message)\n    40→    \n    41→    def log_with_round(self, message: str, round_num: int = None):\n    42→        if round_num is None:\n    43→            round_num = self.round_count\n    44→        timestamp = self.get_timestamp()\n    45→        formatted_message = f\"{{{timestamp}}}-第{round_num}轮-{message}\"\n    46→        with open(self.log_file, \"a\") as f:\n    47→            f.write(formatted_message + \"\\n\")\n    48→        print(formatted_message)\n    49→    \n    50→    def log_json_with_round(self, data: dict | list, message: str, round_num: int = None):\n    51→        if round_num is None:\n    52→            round_num = self.round_count\n    53→        timestamp = self.get_timestamp()\n    54→        pretty = json.dumps(data, ensure_ascii=False, indent=2)\n    55→        formatted_message = f\"{{{timestamp}}}-第{round_num}轮-{message}\\n{pretty}\"\n    56→        with open(self.log_file, \"a\") as f:\n    57→            f.write(formatted_message + \"\\n\")\n    58→        print(formatted_message)\n    59→\n    60→\n    61→app = FastAPI(title=\"Claude Code ↔ DashScope Proxy\")\n    62→logger = AppLogger(\"llm.log\")\n    63→\n    64→\n    65→# ──────────────────────────────────────────────\n    66→# 构造上游请求头\n    67→#\n    68→# 关键差异：\n    69→#   Claude Code 发出：  x-api-key: <anthropic-key>\n    70→#   DashScope 需要：    Authorization: Bearer <dashscope-key>\n    71→# ──────────────────────────────────────────────\n    72→\n    73→PASSTHROUGH_HEADERS = {\"anthropic-version\", \"anthropic-beta\", \"content-type\", \"accept\"}\n    74→\n    75→\n    76→def build_upstream_headers(request: Request) -> dict:\n    77→    headers = {\n    78→        k: v\n    79→        for k, v in request.headers.items()\n    80→        if k.lower() in PASSTHROUGH_HEADERS\n    81→    }\n    82→    # 用 DashScope 的 Key 替换 Anthropic 原生的 x-api-key\n    83→    headers[\"Authorization\"] = f\"Bearer {DASHSCOPE_API_KEY}\"\n    84→    return headers\n    85→\n    86→\n    87→# ──────────────────────────────────────────────\n    88→# /v1/messages  —  流式 & 非流式均支持\n    89→# ──────────────────────────────────────────────\n    90→\n    91→@app.post(\"/v1/messages\")\n    92→async def proxy_messages(request: Request):\n    93→    body_bytes = await request.body()\n    94→    \n    95→    # 增加轮次计数\n    96→    round_num = logger.increment_round()\n    97→\n    98→    try:\n    99→        body = json.loads(body_bytes)\n   100→        # 收集请求信息用于一次性打印\n   101→        request_info = {\n   102→            \"请求轮次\": f\"第{round_num}轮\",\n   103→            \"时间戳\": logger.get_timestamp(),\n   104→            \"原始请求\": body\n   105→        }\n   106→        if isinstance(body, dict):\n   107→            if 'model' in body:\n   108→                request_info[\"模型\"] = body['model']\n   109→            if 'messages' in body:\n   110→                request_info[\"消息数量\"] = len(body['messages'])\n   111→            if 'max_tokens' in body:\n   112→                request_info[\"最大token数\"] = body['max_tokens']\n   113→            if 'temperature' in body:\n   114→                request_info[\"温度参数\"] = body['temperature']\n   115→        logger.log_json_with_round(request_info, \"模型请求完整信息\", round_num)\n   116→    except Exception as e:\n   117→        error_info = {\n   118→            \"请求轮次\": f\"第{round_num}轮\",\n   119→            \"时间戳\": logger.get_timestamp(),\n   120→            \"错误信息\": str(e),\n   121→            \"原始数据\": body_bytes.decode()\n   122→        }\n   123→        logger.log_json_with_round(error_info, \"模型请求解析失败\", round_num)\n   124→        body = {}\n   125→\n   126→    is_stream = body.get(\"stream\", False)\n   127→    upstream_headers = build_upstream_headers(request)\n   128→    upstream_url = f\"{UPSTREAM}/v1/messages\"\n   129→\n   130→    # ── 统一处理所有响应为非流式 ──────────────────────────────\n   131→    # 强制将所有请求转换为非流式处理\n   132→    modified_body = body.copy() if isinstance(body, dict) else {}\n   133→    if 'stream' in modified_body:\n   134→        modified_body['stream'] = False\n   135→    \n   136→    modified_body_bytes = json.dumps(modified_body, ensure_ascii=False).encode() if isinstance(modified_body, dict) else body_bytes\n   137→\n   138→    # ── 统一的非流式响应处理 ────────────────────────────\n   139→    async with httpx.AsyncClient(timeout=None) as client:\n   140→        upstream_resp = await client.post(\n   141→            upstream_url,\n   142→            content=modified_body_bytes,\n   143→            headers=upstream_headers,\n   144→        )\n   145→\n   146→    # 收集完整的响应信息用于格式化打印\n   147→    response_summary = {\n   148→        \"请求轮次\": f\"第{round_num}轮\",\n   149→        \"时间戳\": logger.get_timestamp(),\n   150→        \"上游响应状态码\": upstream_resp.status_code,\n   151→        \"响应头信息\": dict(upstream_resp.headers),\n   152→        \"响应内容长度\": f\"{len(upstream_resp.content)} 字节\"\n   153→    }\n   154→\n   155→    if upstream_resp.status_code >= 400:\n   156→        response_summary[\"错误详情\"] = upstream_resp.text\n   157→        logger.log_json_with_round(response_summary, \"模型响应错误\", round_num)\n   158→    else:\n   159→        try:\n   160→            # 解析并格式化完整的响应内容\n   161→            response_data = upstream_resp.json()\n   162→            response_summary[\"完整响应内容\"] = response_data\n   163→            \n   164→            # 提取关键信息用于快速查看\n   165→            if isinstance(response_data, dict):\n   166→                if 'id' in response_data:\n   167→                    response_summary[\"响应ID\"] = response_data['id']\n   168→                if 'model' in response_data:\n   169→                    response_summary[\"实际使用模型\"] = response_data['model']\n   170→                if 'usage' in response_data:\n   171→                    response_summary[\"Token用量\"] = response_data['usage']\n   172→                if 'content' in response_data:\n   173→                    response_summary[\"响应内容概要\"] = f\"包含{len(response_data['content'])}个内容块\"\n   174→                if 'role' in response_data:\n   175→                    response_summary[\"角色\"] = response_data['role']\n   176→                if 'stop_reason' in response_data:\n   177→                    response_summary[\"停止原因\"] = response_data['stop_reason']\n   178→                \n   179→            logger.log_json_with_round(response_summary, \"模型完整响应\", round_num)\n   180→\n   181→        except Exception as e:\n   182→            response_summary[\"解析错误\"] = str(e)\n   183→            response_summary[\"原始响应文本\"] = upstream_resp.text\n   184→            logger.log_json_with_round(response_summary, \"模型响应解析失败\", round_num)\n   185→\n   186→    return Response(\n   187→        content=upstream_resp.content,\n   188→        status_code=upstream_resp.status_code,\n   189→        headers={\"content-type\": upstream_resp.headers.get(\"content-type\", \"application/json\")},\n   190→    )\n   191→\n   192→\n   193→# ──────────────────────────────────────────────\n   194→# 透传其余 Anthropic 端点\n   195→# ──────────────────────────────────────────────\n   196→\n   197→@app.api_route(\"/v1/{path:path}\", methods=[\"GET\", \"POST\", \"PUT\", \"DELETE\"])\n   198→async def proxy_other(request: Request, path: str):\n   199→    body_bytes = await request.body()\n   200→    upstream_headers = build_upstream_headers(request)\n   201→\n   202→    async with httpx.AsyncClient(timeout=None) as client:\n   203→        upstream_resp = await client.request(\n   204→            method=request.method,\n   205→            url=f\"{UPSTREAM}/v1/{path}\",\n   206→            content=body_bytes,\n   207→            headers=upstream_headers,\n   208→            params=dict(request.query_params),\n   209→        )\n   210→\n   211→    logger.log(f\"[passthrough] {request.method} /v1/{path} → {upstream_resp.status_code}\")\n   212→    if upstream_resp.status_code >= 400:\n   213→        logger.log(f\"[upstream error body] {upstream_resp.text}\")\n   214→\n   215→    return Response(\n   216→        content=upstream_resp.content,\n   217→        status_code=upstream_resp.status_code,\n   218→        headers={\"content-type\": upstream_resp.headers.get(\"content-type\", \"application/json\")},\n   219→    )\n   220→\n   221→\n   222→# ──────────────────────────────────────────────\n   223→\n   224→if __name__ == \"__main__\":\n   225→    import uvicorn\n   226→    uvicorn.run(app, host=\"0.0.0.0\", port=8000)\n   227→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would