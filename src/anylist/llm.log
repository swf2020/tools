                    "type": "string",
                    "enum": [
                      "pending",
                      "in_progress",
                      "completed"
                    ]
                  },
                  "activeForm": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "content",
                  "status",
                  "activeForm"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "todos"
          ],
          "additionalProperties": false
        }
      },
      {
        "name": "WebSearch",
